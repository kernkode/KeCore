# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# Internal REST API
API_PORT=49152
API_KEY=change-me-to-a-long-random-string

# Server endpoints (host:port) — single source of truth, synced into server.cfg on startup
ENDPOINT_TCP=0.0.0.0:30120
ENDPOINT_UDP=0.0.0.0:30120

# FXServer artifact channel: latest | recommended | <build number>
FXSERVER="recommended"

### TxAdmin
USE_TXADMIN=false
TXHOST_TXA_PORT=40121

### Discord bot — your bot token, or "disable" to turn the integration off
DISCORD_TOKEN="disable"
