# Copy this file to `server.cfg` and fill in your own values. `server.cfg` is gitignored.

# Server Configuration
# NOTE: endpoint_add_tcp/udp are auto-synced from .env (ENDPOINT_TCP/ENDPOINT_UDP) on startup — edit them there.
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

# These resources will start by default
exec config.cfg
exec scripts.cfg

sv_scriptHookAllowed 0
sets tags "default"

sets locale "es-ES"

sv_enforceGameBuild 3717 #A Safehouse in the Hills
sv_maxclients 48

# Loading a server icon (96x96 PNG file)
#load_server_icon "logo.png"

# convars which can be used in scripts
set temp_convar "hey world!"
sv_master1 ""

setr sv_stateBagStrictMode false

set steam_webApiKey ""

# Get your key at https://keymaster.fivem.net — do NOT commit a real key
sv_licenseKey "changeme"

# Server tags
sets sv_projectName "KeCore 2.0"
sv_hostname "KeCore DEV"
sets sv_projectDesc "KeCore DevKit"
